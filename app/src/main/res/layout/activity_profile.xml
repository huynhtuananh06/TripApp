<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_cinematic">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ================= USER CARD ================= -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#EEFFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Logout -->

                <TextView
                    android:id="@+id/btnLogout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="🚪 Đăng xuất"
                    android:textStyle="bold"
                    android:textColor="#E53935"
                    android:textSize="15sp"/>

                <!-- Avatar -->

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="10dp">

                    <ImageView
                        android:id="@+id/imgAvatar"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:src="@drawable/ic_user"
                        android:scaleType="centerCrop"
                        android:background="@drawable/circle_bg"
                        android:padding="4dp"/>

                    <ImageView
                        android:id="@+id/btnEditAvatar"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/ic_ground"
                        android:padding="5dp"
                        android:src="@android:drawable/ic_menu_camera"/>

                </FrameLayout>

                <!-- NAME -->

                <TextView
                    android:id="@+id/txtName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginTop="15dp"
                    android:text="Người dùng"
                    android:textColor="#222222"
                    android:textStyle="bold"
                    android:textSize="22sp"/>

                <!-- EMAIL -->

                <TextView
                    android:id="@+id/txtEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginTop="6dp"
                    android:textColor="#666666"
                    android:textSize="15sp"/>



            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ================= ĐƠN HÀNG ================= -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#F7FAFF">

            <TextView
                android:id="@+id/btnAllOrders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="18dp"
                android:text="📦 Tất cả đơn hàng"
                android:textColor="#2D3748"
                android:textSize="18sp"
                android:textStyle="bold"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- ================= DANH SÁCH ================= -->

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerBookedTours"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:paddingBottom="80dp"/>

    </LinearLayout>

    <!-- ================= MENU ================= -->

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_gravity="bottom"
        android:background="#FFFFFF"
        android:elevation="10dp"
        app:itemIconTint="@color/nav_color"
        app:itemTextColor="@color/nav_color"
        app:menu="@menu/bottom_menu"/>

</FrameLayout>